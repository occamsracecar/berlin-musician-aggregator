# Frontend (public)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
NEXT_PUBLIC_SITE_URL=https://berlin-musician-aggregator.vercel.app

# Scraper (server only — never expose in the browser)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Contact messages (server only — Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Berlin Musician Listings <notifications@yourdomain.com>

# Optional: scrape a single board locally
# SCRAPE_BOARD=noisy-rooms.com

# Optional: incremental (new listings only) or full re-scrape
# SCRAPE_INCREMENTAL=true
# SCRAPE_FULL=true
